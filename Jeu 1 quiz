<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Quiz Disney — Signature Host</title>
<link href="https://fonts.googleapis.com/css2?family=Fredoka+One&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
:root{--gold:#C9A84C;--dark:#0a0a1a;--card:#1a1a2e;--blue:#4158D0;--pink:#C850C0;--yellow:#FFD700;--green:#00C851;--red:#FF4444;--white:#fff;}
*{margin:0;padding:0;box-sizing:border-box;}
body{background:var(--dark);font-family:'Nunito',sans-serif;min-height:100vh;overflow-x:hidden;}
.stars{position:fixed;inset:0;pointer-events:none;z-index:0;}
.star{position:absolute;width:3px;height:3px;background:white;border-radius:50%;animation:twinkle 3s infinite;}
@keyframes twinkle{0%,100%{opacity:.2}50%{opacity:1}}
.wrap{position:relative;z-index:1;max-width:480px;margin:0 auto;padding:20px 16px;min-height:100vh;display:flex;flex-direction:column;}
.header{text-align:center;padding:20px 0 16px;}
.header .castle{font-size:3rem;animation:float 3s ease-in-out infinite;}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
.header h1{font-family:'Fredoka One',cursive;font-size:2rem;color:#C9A84C;margin:6px 0 4px;}
.header p{color:rgba(255,255,255,.6);font-size:.85rem;}
.score-bar{display:flex;justify-content:space-between;align-items:center;background:rgba(255,255,255,.06);border:1px solid rgba(201,168,76,.2);border-radius:12px;padding:10px 16px;margin-bottom:20px;}
.score-item{text-align:center;}
.score-num{font-family:'Fredoka One',cursive;font-size:1.6rem;color:var(--gold);}
.score-label{font-size:.7rem;color:rgba(255,255,255,.5);text-transform:uppercase;}
.progress-ring{display:flex;align-items:center;gap:6px;color:rgba(255,255,255,.7);font-size:.8rem;}
.ring-fill{height:6px;background:rgba(255,255,255,.1);border-radius:3px;width:80px;overflow:hidden;}
.ring-inner{height:100%;background:linear-gradient(90deg,var(--gold),#fff59d);border-radius:3px;transition:width .4s;}
.q-card{background:rgba(65,88,208,.15);border:1px solid rgba(255,255,255,.12);border-radius:24px;padding:24px 20px 20px;margin-bottom:16px;}
.q-num{font-size:.75rem;font-weight:700;color:var(--gold);text-transform:uppercase;margin-bottom:8px;}
.q-emoji{font-size:2.5rem;display:block;margin-bottom:10px;text-align:center;}
.q-text{font-size:1.1rem;font-weight:700;color:white;text-align:center;line-height:1.4;}
.answers{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:20px;}
.ans-btn{background:rgba(255,255,255,.07);border:1.5px solid rgba(255,255,255,.12);border-radius:16px;padding:14px 10px;color:white;font-family:'Nunito',sans-serif;font-size:.9rem;font-weight:700;cursor:pointer;text-align:center;transition:all .2s;line-height:1.3;}
.ans-btn.correct{background:rgba(0,200,81,.2);border-color:var(--green);color:var(--green);}
.ans-btn.wrong{background:rgba(255,68,68,.2);border-color:var(--red);color:var(--red);}
.ans-btn:disabled{cursor:default;}
.feedback{text-align:center;padding:12px;border-radius:12px;font-weight:700;font-size:1rem;margin-bottom:16px;}
.feedback.good{background:rgba(0,200,81,.15);color:var(--green);}
.feedback.bad{background:rgba(255,68,68,.12);color:#ff7777;}
.next-btn{width:100%;padding:16px;background:linear-gradient(135deg,var(--gold),#f0d060);border:none;border-radius:16px;font-family:'Fredoka One',cursive;font-size:1.2rem;color:#1a1000;cursor:pointer;}
.next-btn:disabled{opacity:.3;cursor:default;}
.end-screen{text-align:center;padding:30px 20px;}
.end-trophy{font-size:4rem;margin-bottom:10px;}
.end-score{font-family:'Fredoka One',cursive;font-size:3.5rem;color:var(--gold);}
.end-msg{color:rgba(255,255,255,.8);font-size:1rem;margin:8px 0 20px;line-height:1.5;}
.restart-btn{background:linear-gradient(135deg,var(--blue),var(--pink));border:none;border-radius:16px;padding:16px 32px;font-family:'Fredoka One',cursive;font-size:1.2rem;color:white;cursor:pointer;}
.brand{text-align:center;padding:12px 0 4px;color:rgba(255,255,255,.2);font-size:.7rem;}
</style>
</head>
<body>
<div class="stars" id="stars"></div>
<div class="wrap">
<div class="header">
<div class="castle">&#127968;</div>
<h1>Quiz Disney !</h1>
<p>10 questions magiques</p>
</div>
<div class="score-bar">
<div class="score-item"><div class="score-num" id="score-disp">0</div><div class="score-label">Points</div></div>
<div class="progress-ring"><span id="q-counter">1/10</span><div class="ring-fill"><div class="ring-inner" id="ring" style="width:10%"></div></div></div>
<div class="score-item"><div class="score-num" id="streak-disp">0</div><div class="score-label">Serie</div></div>
</div>
<div id="game-area">
<div class="q-card" id="q-card">
<div class="q-num" id="q-num">Question 1 sur 10</div>
<span class="q-emoji" id="q-emoji">&#127907;</span>
<div class="q-text" id="q-text">Chargement...</div>
</div>
<div class="answers" id="answers"></div>
<div class="feedback" id="feedback" style="display:none"></div>
<button class="next-btn" id="next-btn" onclick="nextQ()" disabled>Suivant</button>
</div>
<div id="end-screen" class="end-screen" style="display:none">
<div class="end-trophy" id="end-trophy">&#127942;</div>
<div class="end-score" id="end-score">0/10</div>
<div class="end-msg" id="end-msg">Bravo !</div>
<button class="restart-btn" onclick="restart()">Rejouer !</button>
</div>
<div class="brand">Signature Host — Disneyland Paris</div>
</div>
<script>
const Q=[
{e:'&#129409;',q:'Dans Le Roi Lion, comment appelle le mechant oncle de Simba ?',a:['Scar','Mufasa','Zazu','Pumbaa'],c:0},
{e:'&#10052;',q:'Dans La Reine des Neiges, quelle est la chanson la plus celebre ?',a:['Liberee, delivree','Let it go','Into the unknown','Some things never change'],c:0},
{e:'&#128032;',q:'Dans Le Monde de Nemo, quel poisson aide a trouver Nemo ?',a:['Dory','Gill','Bloat','Jacques'],c:0},
{e:'&#129680;',q:'Dans Aladdin, combien de voeux peut-on faire avec la lampe ?',a:['3','1','10','7'],c:0},
{e:'&#129302;',q:'Dans Les Indestructibles, quel est le super-pouvoir de Violette ?',a:['Champs de force','Super vitesse','Super force','Elasticite'],c:0},
{e:'&#129528;',q:'Dans Toy Story, comment appelle le cowboy jouet ?',a:['Woody','Buzz','Rex','Ham'],c:0},
{e:'&#128045;',q:'En quelle annee Mickey Mouse a-t-il ete cree ?',a:['1928','1935','1923','1940'],c:0},
{e:'&#127929;',q:'Dans La Belle et la Bete, comment appelle le chandelier ?',a:['Lumiere','Zip','Flash','Bougie'],c:0},
{e:'&#127984;',q:'Comment appelle le chateau de Disneyland Paris ?',a:['Chateau de la Belle au Bois Dormant','Chateau de Cendrillon','Chateau de Blanche-Neige','Chateau Enchante'],c:0},
{e:'&#128032;',q:'Dans Le Monde de Nemo, dans quel ocean se deroule histoire ?',a:['Pacifique','Atlantique','Indien','Arctique'],c:0},
];
let cur=0,score=0,streak=0,answered=false;
function render(){
const q=Q[cur];
document.getElementById('q-num').textContent='Question '+(cur+1)+' sur '+Q.length;
document.getElementById('q-emoji').innerHTML=q.e;
document.getElementById('q-text').textContent=q.q;
document.getElementById('q-counter').textContent=(cur+1)+'/'+Q.length;
document.getElementById('ring').style.width=((cur+1)/Q.length*100)+'%';
document.getElementById('feedback').style.display='none';
document.getElementById('next-btn').disabled=true;
document.getElementById('next-btn').textContent=cur===Q.length-1?'Voir mon score':'Suivant';
answered=false;
const aa=document.getElementById('answers');aa.innerHTML='';
[...q.a.keys()].sort(()=>Math.random()-.5).forEach(i=>{
const b=document.createElement('button');b.className='ans-btn';b.textContent=q.a[i];b.dataset.idx=i;b.onclick=()=>pick(b,i);aa.appendChild(b);
});
}
function pick(btn,idx){
if(answered)return;answered=true;
const q=Q[cur];
document.querySelectorAll('.ans-btn').forEach(b=>{b.disabled=true;if(parseInt(b.dataset.idx)===q.c)b.classList.add('correct');});
const fb=document.getElementById('feedback');
if(idx===q.c){score++;streak++;btn.classList.add('correct');fb.textContent=streak>2?'Serie de '+streak+' ! Excellent !':'Bonne reponse !';fb.className='feedback good';}
else{btn.classList.add('wrong');streak=0;fb.textContent='C etait : '+q.a[q.c];fb.className='feedback bad';}
fb.style.display='block';
document.getElementById('score-disp').textContent=score;
document.getElementById('streak-disp').textContent=streak;
document.getElementById('next-btn').disabled=false;
}
function nextQ(){cur++;if(cur>=Q.length){showEnd();}else{render();}}
function showEnd(){
document.getElementById('game-area').style.display='none';
document.getElementById('end-screen').style.display='block';
const p=score/Q.length;
let t,m;
if(p>=.9){t='&#127942;';m='Incroyable ! Tu es un vrai expert Disney !';}
else if(p>=.7){t='&#129351;';m='Tres bien ! Tu connais Disney sur le bout des doigts !';}
else if(p>=.5){t='&#129352;';m='Pas mal ! Encore quelques films a regarder ce soir ?';}
else{t='&#127907;';m='Continue d explorer la magie Disney !';}
document.getElementById('end-trophy').innerHTML=t;
document.getElementById('end-score').textContent=score+'/'+Q.length;
document.getElementById('end-msg').textContent=m;
}
function restart(){cur=0;score=0;streak=0;document.getElementById('end-screen').style.display='none';document.getElementById('game-area').style.display='block';document.getElementById('score-disp').textContent='0';document.getElementById('streak-disp').textContent='0';Q.sort(()=>Math.random()-.5);render();}
const sf=document.getElementById('stars');
for(let i=0;i<60;i++){const s=document.createElement('div');s.className='star';s.style.cssText='left:'+Math.random()*100+'%;top:'+Math.random()*100+'%;width:'+(Math.random()*3+1)+'px;height:'+(Math.random()*3+1)+'px;animation-delay:'+Math.random()*3+'s;animation-duration:'+(2+Math.random()*3)+'s;';sf.appendChild(s);}
render();
</script>
</body>
</html>
